{
  "name": "tauri-app",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:visual": "VITE_VISUAL_BENCH=1 vite build && playwright test -c tests/visual",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "build:web": "vite build",
    "test:frontend": "vitest run",
    "test:sidecar": "npm --prefix sidecar test",
    "test:gallery:unit": "python3 -m unittest discover -s gallery/tests",
    "test:gallery:parity": "cd gallery && node server/tests/parity.mjs",
    "test:gallery:diff": "node gallery/server/tests/diff_suite.mjs",
    "test:gallery": "npm run test:gallery:unit && npm run test:gallery:parity && npm run test:gallery:diff",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "test:rust-workspace": "cargo test --manifest-path rust/Cargo.toml --locked",
    "test:protocol": "npm --prefix packages/atelier-protocol test",
    "protocol:export-fixtures": "node --experimental-strip-types packages/atelier-protocol/scripts/export-fixtures.ts",
    "check:backend-policy": "node scripts/check-backend-policy.mjs",
    "soak:sidecar": "bash scripts/soak-rust-sidecar.sh",
    "verify": "npm run typecheck && npm run build:web && node scripts/check_entry_budget.mjs && npm run test:frontend && npm run test:sidecar && npm run test:gallery && npm run test:rust && npm run test:protocol && npm run test:rust-workspace && npm run check:backend-policy",
    "verify:e2e": "npm --prefix gallery run test:e2e"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.22",
    "mermaid": "^11",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
